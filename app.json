{
  "expo": {
    "name": "Seva Eats",
    "slug": "sev-eats",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "scheme": "seveats",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.advay.sewaeats",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "We use your location to show nearby sewa drop-off points and delivery updates."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1A1F25",
        "foregroundImage": "./assets/images/logo.png"
      },
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION"
      ],
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.advay.sewaeats"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/logo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-widgets",
        {
          "groupIdentifier": "group.com.advay.sewaeats",
          "enablePushNotifications": false,
          "widgets": []
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FFFFFF",
          "dark": {
            "backgroundColor": "#1A1F25"
          }
        }
      ],
      "expo-font",
      "expo-image",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
