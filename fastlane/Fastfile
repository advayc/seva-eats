default_platform(:ios)

platform :ios do
  desc "CI lane: build and upload to App Store Connect"
  lane :ci do
    api_key = app_store_connect_api_key(
      key_id: ENV['APP_STORE_CONNECT_KEY_ID'],
      issuer_id: ENV['APP_STORE_CONNECT_ISSUER_ID'],
      key_content: File.read(ENV['APP_STORE_CONNECT_API_KEY_PATH'])
    )

    # Optional: use fastlane match if MATCH_GIT_URL is provided
    if ENV['MATCH_GIT_URL'] && ENV['MATCH_GIT_URL'] != ''
      match(git_url: ENV['MATCH_GIT_URL'], readonly: false, type: "appstore", password: ENV['MATCH_PASSWORD'])
    end

    build_app(
      workspace: "ios/SevaEats.xcworkspace",
      scheme: "SevaEats",
      export_method: "app-store",
      api_key: api_key
    )

    upload_to_app_store(api_key: api_key)
  end
end
